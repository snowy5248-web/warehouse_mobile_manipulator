<?xml version="1.0"?>
<robot name="warehouse_mobile_manipulator">

  <!-- ================= Virtual root link at ground level ================= -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <!-- Chassis raised 0.2m so its bottom sits above the wheel axle,
         preventing the chassis from visually clipping into the wheels -->
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
  </joint>

  <!-- ================= 1. MOBILE BASE ================= -->
  <!-- Chassis: Blue -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.5 0.3 0.2"/></geometry>
      <material name="blue"><color rgba="0 0 0.8 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.5 0.3 0.2"/></geometry>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.2" iyz="0.0" izz="0.2"/>
    </inertial>
  </link>
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>

  <!-- Left wheel: Black -->
  <link name="left_wheel">
    <visual>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>
  <gazebo reference="left_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <!-- LEFT WHEEL JOINT -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- y = +0.175 (half chassis width 0.15 + half wheel thickness 0.025) -->
    <!-- z = -0.1: base_link is now 0.2m above ground, wheel center (radius 0.1)
         must be 0.1m above ground -> offset -0.1 relative to base_link origin -->
    <origin xyz="0 0.175 -0.1" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Right wheel: Black -->
  <link name="right_wheel">
    <visual>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>
  <gazebo reference="right_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <!-- RIGHT WHEEL JOINT -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.175 -0.1" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Rear caster wheel: Grey -->
  <link name="caster_wheel">
    <visual>
      <geometry><sphere radius="0.05"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>
  <gazebo reference="caster_wheel">
    <material>Gazebo/Grey</material>
    <!-- Low friction so the caster slides freely and doesn't resist differential drive -->
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <!-- REAR CASTER WHEEL JOINT -->
  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <!-- Rear of chassis, negative x; sphere center (radius 0.05) must be
         0.05m above ground -> offset -0.15 relative to base_link (now 0.2m above ground) -->
    <origin xyz="-0.2 0 -0.15" rpy="0 0 0"/>
    <child link="caster_wheel"/>
  </joint>

  <!-- Front caster wheel: added to prevent the chassis from tipping forward
       (with only a rear caster, the front half of the chassis had no support point) -->
  <link name="caster_wheel_front">
    <visual>
      <geometry><sphere radius="0.05"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>
  <gazebo reference="caster_wheel_front">
    <material>Gazebo/Grey</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <!-- FRONT CASTER WHEEL JOINT -->
  <joint name="caster_wheel_front_joint" type="fixed">
    <parent link="base_link"/>
    <!-- Symmetric to rear caster: positive x (front), same height -0.15 -->
    <origin xyz="0.2 0 -0.15" rpy="0 0 0"/>
    <child link="caster_wheel_front"/>
  </joint>

  <!-- ================= LIDAR SENSOR ================= -->
  <!-- LiDAR: Orange -->
  <link name="laser_frame">
    <visual>
      <geometry><cylinder radius="0.05" length="0.05"/></geometry>
      <material name="orange"><color rgba="1 0.5 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.05" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0002"/>
    </inertial>
  </link>
  <gazebo reference="laser_frame">
    <material>Gazebo/Orange</material>
  </gazebo>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="0.15 0 0.15" rpy="0 0 0"/>
  </joint>

  <!-- ================= 2. MANIPULATOR ARM (RR CONFIGURATION) ================= -->
  <!-- Arm base: Grey -->
  <link name="arm_base_link">
    <visual>
      <geometry><cylinder radius="0.04" length="0.02"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.02"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <gazebo reference="arm_base_link">
    <material>Gazebo/Grey</material>
  </gazebo>

  <joint name="arm_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- Revolute link 1: Red -->
  <link name="arm_link1">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.3"/></geometry>
      <material name="red"><color rgba="0.8 0 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.3"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.004" ixy="0.0" ixz="0.0" iyy="0.004" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <gazebo reference="arm_link1">
    <material>Gazebo/Red</material>
  </gazebo>

  <joint name="joint1" type="revolute">
    <parent link="arm_base_link"/>
    <child link="arm_link1"/>
    <origin xyz="0 0 0.01" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
    <!-- Damping/friction added: no controller holds this joint in Gazebo.
         Without dynamics, the joint would free-fall under gravity and
         oscillate like a pendulum and never settle -->
    <dynamics damping="5.0" friction="1.0"/>
  </joint>

  <!-- Revolute link 2: Green -->
  <link name="arm_link2">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.3"/></geometry>
      <material name="green"><color rgba="0 0.8 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.3"/></geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <gazebo reference="arm_link2">
    <material>Gazebo/Green</material>
  </gazebo>

  <joint name="joint2" type="revolute">
    <parent link="arm_link1"/>
    <child link="arm_link2"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>

  <!-- Virtual end-effector frame -->
  <link name="gripper_touchpoint"/>
  <joint name="gripper_touchpoint_joint" type="fixed">
    <parent link="arm_link2"/>
    <child link="gripper_touchpoint"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
  </joint>

  <!-- Drive and sensor plugins -->
  <gazebo>
    <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <leftJoint>left_wheel_joint</leftJoint>
      <rightJoint>right_wheel_joint</rightJoint>
      <robotBaseFrame>base_footprint</robotBaseFrame>
      <wheelSeparation>0.35</wheelSeparation>
      <wheelDiameter>0.2</wheelDiameter>
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <updateRate>30</updateRate>
      <publishOdomTF>true</publishOdomTF>
      <publishWheelTF>false</publishWheelTF>
      <!-- Disabled: prevents Gazebo from also publishing /joint_states for the
           wheel joints, which would conflict with joint_state_publisher_gui
           publishing arm joint states on the same topic -->
      <publishWheelJointState>false</publishWheelJointState>
    </plugin>
  </gazebo>

  <gazebo reference="laser_frame">
    <sensor type="ray" name="laser">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.1</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="gazebo_ros_laser_controller" filename="libgazebo_ros_laser.so">
        <topicName>scan</topicName>
        <frameName>laser_frame</frameName>
      </plugin>
    </sensor>
  </gazebo>

</robot>
