<?xml version="1.0"?>
<robot name="warehouse_mobile_manipulator">

  <!-- ================= Khâu gốc ảo sát mặt đất ================= -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <!-- Nâng thân xe lên 0.2m (thay vì 0.1m) để đáy thân cao hơn tâm trục bánh xe,
         tránh thân xe "lún" vào bánh xe như trước -->
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
  </joint>

  <!-- ================= 1. ĐẾ DI ĐỘNG (MOBILE BASE) ================= -->
  <!-- Thân xe: Màu Xanh Dương -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.5 0.3 0.2"/></geometry>
      <material name="blue"><color rgba="0 0 0.8 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.5 0.3 0.2"/></geometry>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.2" iyz="0.0" izz="0.2"/>
    </inertial>
  </link>
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>

  <!-- Bánh xe Trái: Màu Đen -->
  <link name="left_wheel">
    <visual>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>
  <gazebo reference="left_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <!-- KHỚP NỐI BÁNH XE TRÁI (bị thiếu ở bản gốc) -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- y = +0.175 (nửa bề rộng thân 0.15 + nửa bề dày bánh 0.025) -->
    <!-- z = -0.1: base_link giờ cao 0.2m so với đất, tâm bánh (bán kính 0.1) phải ở độ cao
         0.1m so với đất -> lệch xuống 0.1m so với gốc base_link -->
    <origin xyz="0 0.175 -0.1" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Bánh xe Phải: Màu Đen -->
  <link name="right_wheel">
    <visual>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>
  <gazebo reference="right_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <!-- KHỚP NỐI BÁNH XE PHẢI (bị thiếu ở bản gốc) -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.175 -0.1" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Bánh xe Caster: Màu Xám -->
  <link name="caster_wheel">
    <visual>
      <geometry><sphere radius="0.05"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>
  <gazebo reference="caster_wheel">
    <material>Gazebo/Grey</material>
    <!-- Ma sát thấp để bánh caster trượt tự do, không cản trở di chuyển vi sai -->
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <!-- KHỚP NỐI BÁNH CASTER (bị thiếu ở bản gốc) -->
  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <!-- Đặt phía sau thân xe, x âm; tâm quả cầu (bán kính 0.05) phải cao 0.05m so với đất
         -> lệch xuống 0.15m so với gốc base_link (đang cao 0.2m so với đất) -->
    <origin xyz="-0.2 0 -0.15" rpy="0 0 0"/>
    <child link="caster_wheel"/>
  </joint>
  <!-- Bánh xe Caster PHÍA TRƯỚC (thêm để chống chúi mũi xuống đất) -->
  <link name="caster_wheel_front">
    <visual>
      <geometry><sphere radius="0.05"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>
  <gazebo reference="caster_wheel_front">
    <material>Gazebo/Grey</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <joint name="caster_wheel_front_joint" type="fixed">
    <parent link="base_link"/>
    <!-- Đối xứng với caster sau: x dương (phía trước), cùng độ cao -0.15 -->
    <origin xyz="0.2 0 -0.15" rpy="0 0 0"/>
    <child link="caster_wheel_front"/>
  </joint>
	
  <!-- ================= CẢM BIẾN LIDAR ================= -->
  <!-- LiDAR: Màu Cam -->
  <link name="laser_frame">
    <visual>
      <geometry><cylinder radius="0.05" length="0.05"/></geometry>
      <material name="orange"><color rgba="1 0.5 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.05" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0002"/>
    </inertial>
  </link>
  <gazebo reference="laser_frame">
    <material>Gazebo/Orange</material>
  </gazebo>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="0.15 0 0.15" rpy="0 0 0"/>
  </joint>

  <!-- ================= 2. TAY MÁY GẮP HÀNG (MANIPULATOR RR) ================= -->
  <!-- Đế tay máy: Màu Xám -->
  <link name="arm_base_link">
    <visual>
      <geometry><cylinder radius="0.04" length="0.02"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.02"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <gazebo reference="arm_base_link">
    <material>Gazebo/Grey</material>
  </gazebo>

  <joint name="arm_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- Khâu xoay 1: Màu Đỏ -->
  <link name="arm_link1">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.3"/></geometry>
      <material name="red"><color rgba="0.8 0 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.3"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.004" ixy="0.0" ixz="0.0" iyy="0.004" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <gazebo reference="arm_link1">
    <material>Gazebo/Red</material>
  </gazebo>

  <joint name="joint1" type="revolute">
    <parent link="arm_base_link"/>
    <child link="arm_link1"/>
    <origin xyz="0 0 0.01" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
    <!-- Thêm damping/friction: không có bộ điều khiển (controller) nào giữ khớp này
         trong Gazebo, nếu không có dynamics, khớp sẽ rơi tự do dưới trọng lực và
         dao động lên xuống như con lắc, không bao giờ dừng -->
    <dynamics damping="5.0" friction="1.0"/>
  </joint>

  <!-- Khâu xoay 2: Màu Xanh Lá -->
  <link name="arm_link2">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.3"/></geometry>
      <material name="green"><color rgba="0 0.8 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.3"/></geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <gazebo reference="arm_link2">
    <material>Gazebo/Green</material>
  </gazebo>

  <joint name="joint2" type="revolute">
    <parent link="arm_link1"/>
    <child link="arm_link2"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>

  <!-- Hệ tọa độ ảo đầu gắp -->
  <link name="gripper_touchpoint"/>
  <joint name="gripper_touchpoint_joint" type="fixed">
    <parent link="arm_link2"/>
    <child link="gripper_touchpoint"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
  </joint>

  <!-- Plugins Truyền động & Cảm biến -->
  <gazebo>
    <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <leftJoint>left_wheel_joint</leftJoint>
      <rightJoint>right_wheel_joint</rightJoint>
      <robotBaseFrame>base_footprint</robotBaseFrame>
      <wheelSeparation>0.35</wheelSeparation>
      <wheelDiameter>0.2</wheelDiameter>
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <updateRate>30</updateRate>
      <publishOdomTF>true</publishOdomTF>
      <publishWheelTF>false</publishWheelTF>
      <publishWheelJointState>false</publishWheelJointState>
    </plugin>
  </gazebo>

  <gazebo reference="laser_frame">
    <sensor type="ray" name="laser">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.1</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="gazebo_ros_laser_controller" filename="libgazebo_ros_laser.so">
        <topicName>scan</topicName>
        <frameName>laser_frame</frameName>
      </plugin>
    </sensor>
  </gazebo>

</robot>
