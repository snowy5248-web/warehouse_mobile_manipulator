<?xml version="1.0"?>
<robot name="warehouse_robot">

  <!-- ============================================================= -->
  <!-- Materials                                                      -->
  <!-- ============================================================= -->
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.5 0.0 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.1 0.3 0.9 1.0"/>
  </material>

  <!-- ============================================================= -->
  <!-- BASE_LINK  (chassis, size 0.5 x 0.4 x 0.2, origin at box center)-->
  <!-- Ground clearance: box bottom / wheel bottom sit at z = -0.10   -->
  <!-- relative to base_link -> base_link is 0.10 m above the ground  -->
  <!-- ============================================================= -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.4 0.2"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.4 0.2"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0708" ixy="0.0" ixz="0.0" iyy="0.1042" iyz="0.0" izz="0.1708"/>
    </inertial>
  </link>

  <gazebo reference="base_link">
    <material>Gazebo/Grey</material>
  </gazebo>

  <!-- ============================================================= -->
  <!-- DRIVE WHEELS (left / right, continuous joints about local Y)  -->
  <!-- ============================================================= -->
  <link name="wheel_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00058" ixy="0.0" ixz="0.0" iyy="0.00058" iyz="0.0" izz="0.0016"/>
    </inertial>
  </link>

  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0 0.22 -0.02" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <link name="wheel_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00058" ixy="0.0" ixz="0.0" iyy="0.00058" iyz="0.0" izz="0.0016"/>
    </inertial>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0 -0.22 -0.02" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <gazebo reference="wheel_left_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="wheel_right_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <!-- ============================================================= -->
  <!-- CASTER WHEEL (free-rolling support wheel, rear of chassis)     -->
  <!-- ============================================================= -->
  <link name="caster_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00013" ixy="0.0" ixz="0.0" iyy="0.00013" iyz="0.0" izz="0.00013"/>
    </inertial>
  </link>

  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel_link"/>
    <origin xyz="-0.20 0 -0.06" rpy="0 0 0"/>
  </joint>

  <gazebo reference="caster_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <!-- ============================================================= -->
  <!-- LIDAR: no dedicated URDF link. The Gazebo ray sensor is        -->
  <!-- attached directly to base_link with a pose offset, and it      -->
  <!-- publishes /scan with frame_id="laser_frame". The transform     -->
  <!-- base_link -> laser_frame is supplied separately by             -->
  <!-- src/static_broadcaster.cpp using the SAME offset below:        -->
  <!--   x = 0.15 (15 cm in front of center)                          -->
  <!--   z = 0.15 (top surface at z=0.10, +0.05 above it)              -->
  <!-- ============================================================= -->
  <gazebo reference="base_link">
    <sensor type="ray" name="lidar_sensor">
      <pose>0.15 0 0.15 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="gazebo_ros_laser" filename="libgazebo_ros_laser.so">
        <topicName>/scan</topicName>
        <frameName>laser_frame</frameName>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ============================================================= -->
  <!-- MANIPULATOR: 2-DOF RR arm mounted at the center of the top     -->
  <!-- surface of the mobile base.                                    -->
  <!-- ============================================================= -->
  <link name="arm_base_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <inertia ixx="0.0003" ixy="0.0" ixz="0.0" iyy="0.0003" iyz="0.0" izz="0.0004"/>
    </inertial>
  </link>

  <joint name="arm_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base_link"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
  </joint>

  <gazebo reference="arm_base_link">
    <material>Gazebo/Orange</material>
  </gazebo>

  <!-- Shoulder: revolute, pitch about local Y -->
  <link name="arm_link1">
    <visual>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.06 0.25"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.06 0.25"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <inertia ixx="0.0022" ixy="0.0" ixz="0.0" iyy="0.0022" iyz="0.0" izz="0.00024"/>
    </inertial>
  </link>

  <joint name="arm_shoulder_joint" type="revolute">
    <parent link="arm_base_link"/>
    <child link="arm_link1"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="50" velocity="1.0" lower="-1.5708" upper="1.5708"/>
    <dynamics damping="1.0" friction="0.5"/>
  </joint>

  <gazebo reference="arm_link1">
    <material>Gazebo/Blue</material>
  </gazebo>

  <!-- Elbow: revolute, pitch about local Y -->
  <link name="arm_link2">
    <visual>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.20"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.20"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <inertia ixx="0.0011" ixy="0.0" ixz="0.0" iyy="0.0011" iyz="0.0" izz="0.00013"/>
    </inertial>
  </link>

  <joint name="arm_elbow_joint" type="revolute">
    <parent link="arm_link1"/>
    <child link="arm_link2"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="50" velocity="1.0" lower="-1.5708" upper="1.5708"/>
    <dynamics damping="1.0" friction="0.5"/>
  </joint>

  <gazebo reference="arm_link2">
    <material>Gazebo/Orange</material>
  </gazebo>

  <!-- Virtual end-effector frame, no mass, fixed to the tip of arm_link2 -->
  <link name="gripper_touchpoint">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="gripper_touchpoint_joint" type="fixed">
    <parent link="arm_link2"/>
    <child link="gripper_touchpoint"/>
    <origin xyz="0 0 0.20" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================= -->
  <!-- ros_control transmissions for the two arm joints (needed once  -->
  <!-- you wire up position controllers in section 2.4)               -->
  <!-- ============================================================= -->
  <transmission name="tran_shoulder">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="arm_shoulder_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor_shoulder">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="tran_elbow">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="arm_elbow_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor_elbow">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <gazebo>
    <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
      <robotNamespace>/warehouse_mobile_manipulator</robotNamespace>
    </plugin>
  </gazebo>

  <!-- ============================================================= -->
  <!-- Differential drive plugin: publishes odom -> base_link          -->
  <!-- ============================================================= -->
  <gazebo>
    <plugin name="diff_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <legacyMode>false</legacyMode>
      <alwaysOn>true</alwaysOn>
      <updateRate>50</updateRate>
      <leftJoint>wheel_left_joint</leftJoint>
      <rightJoint>wheel_right_joint</rightJoint>
      <wheelSeparation>0.44</wheelSeparation>
      <wheelDiameter>0.16</wheelDiameter>
      <torque>10</torque>
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_link</robotBaseFrame>
      <publishWheelTF>false</publishWheelTF>
      <publishOdomTF>true</publishOdomTF>
      <publishWheelJointState>true</publishWheelJointState>
    </plugin>
  </gazebo>

</robot>

